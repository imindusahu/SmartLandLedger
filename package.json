{
    "name": "land-registration-blockchain",
    "version": "1.0.0",
    "description": "Decentralized Land Registration System using Hardhat & Next.js",
    "scripts": {
        "hardhat:node": "hardhat node",
        "hardhat:compile": "hardhat compile",
        "hardhat:deploy": "hardhat run scripts/deploy.js",
        "hardhat:test": "hardhat test",
        "app:dev": "cd app && npm run dev",
        "app:build": "cd app && npm run build",
        "app:start": "cd app && npm start",
        "dev": "concurrently \"npm run hardhat:node\" \"npm run app:dev\"",
        "test": "hardhat test"
    },
    "devDependencies": {
        "hardhat": "^2.19.4",
        "@nomicfoundation/hardhat-toolbox": "^3.0.0",
        "@nomicfoundation/hardhat-ethers": "^3.0.5",
        "ethers": "^6.10.0",
        "concurrently": "^8.2.2"
    },
    "dependencies": {}
}